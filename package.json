{
  "name": "genthumb",
  "version": "1.0.0",
  "description": "Generate fast WebP thumbnails from images, PDFs, Office files, spreadsheets, and text",
  "main": "index.js",
  "types": "index.d.ts",
  "author": {
    "name": "Mon Albert Gamil",
    "email": "mrgamilmonalbert@gmail.com",
    "url": "https://github.com/xcvzmoon/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xcvzmoon/genthumb.git"
  },
  "license": "MIT",
  "browser": "browser.js",
  "keywords": [
    "genthumb",
    "thumbnail",
    "preview",
    "document",
    "pdf",
    "image",
    "office",
    "file"
  ],
  "files": [
    "index.d.ts",
    "index.js",
    "index.mjs",
    "browser.js"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "browser": "./browser.js",
      "import": "./index.mjs",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "napi": {
    "binaryName": "genthumb",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">= 12.22.0 < 13 || >= 14.17.0 < 15 || >= 15.12.0 < 16 || >= 16.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "vitest bench",
    "build": "napi build --platform --release --js index.js && napi build --platform --release --esm --js index.mjs",
    "build:debug": "napi build --platform --js index.js && napi build --platform --esm --js index.mjs",
    "format": "run-p format:oxfmt format:rs format:toml",
    "format:oxfmt": "oxfmt && oxfmt --check",
    "format:toml": "taplo format",
    "format:rs": "cargo fmt",
    "lint": "oxlint --type-aware",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "vitest --run",
    "preversion": "npm run build:debug && git add .",
    "version": "napi version",
    "prepare": "husky",
    "changelog": "changelogen",
    "changelog:bump": "changelogen --bump",
    "changelog:release": "changelogen --release"
  },
  "devDependencies": {
    "@emnapi/core": "^1.8.1",
    "@emnapi/runtime": "^1.8.1",
    "@napi-rs/cli": "^3.5.1",
    "@oxc-node/core": "^0.0.35",
    "@taplo/cli": "^0.7.0",
    "@tybys/wasm-util": "^0.10.1",
    "@types/bun": "latest",
    "@types/node": "^25.3.1",
    "chalk": "^5.6.2",
    "changelogen": "^0.6.2",
    "consola": "^3.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.31.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.12.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "genthumb-win32-x64-msvc": "1.0.0",
    "genthumb-darwin-x64": "1.0.0",
    "genthumb-linux-x64-gnu": "1.0.0",
    "genthumb-darwin-arm64": "1.0.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "oxlint --fix"
    ],
    "*.{js,ts,json,jsonc,md,yml,yaml}": [
      "oxfmt ."
    ],
    "*.toml": [
      "taplo format"
    ]
  },
  "packageManager": "bun@1.3.10"
}
